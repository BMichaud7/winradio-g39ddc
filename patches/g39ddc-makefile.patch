--- a/driver/Makefile	2026-06-21 20:51:32.101001072 -0400
+++ b/driver/Makefile	2026-06-21 20:51:32.106026571 -0400
@@ -2,6 +2,10 @@
 obj-m := g39ddc.o
 KERNELDIR ?= /lib/modules/$(shell uname -r)/build
 PWD := $(shell pwd)
+# Modern kernels (>=2.6.36) only have unlocked_ioctl/compat_ioctl, not the
+# old struct-inode-taking .ioctl -- this vendor driver predates that and
+# gates on these defines, which its build never actually set.
+ccflags-y := -DHAVE_UNLOCKED_IOCTL -DHAVE_COMPAT_IOCTL
 
 all:
 	$(MAKE) -C $(KERNELDIR) M=$(PWD) modules
