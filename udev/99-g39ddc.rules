# WiNRADiO G39DDC -- let any local user open the device node without sudo,
# matching how other SDR vendors (rtl-sdr, hackrf, etc.) ship their udev
# rules. Mode 0666 rather than a dedicated group, since this is a
# single-user dev machine and the device has no destructive/privileged
# operations exposed via the ioctl interface.
SUBSYSTEM=="usb", ATTR{idVendor}=="14e0", ATTR{idProduct}=="1109", MODE="0666"
KERNEL=="g39ddc*", MODE="0666"
